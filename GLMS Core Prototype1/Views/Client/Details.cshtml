@model GLMS_Core_Prototype.Models.Client
@{
    ViewData["Title"] = "Client Details";
    Layout = "_Layout";
}

<h2>Client Details</h2>
<p>Name: @Model.Name</p>
<p>Contact: @Model.ContactDetails</p>
<p>Region: @Model.Region</p>

<a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@Model.ClientId">Edit</a>
<a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@Model.ClientId">Delete</a>
