@model IEnumerable<GLMS_Core_Prototype.Models.Client>
@{
    ViewData["Title"] = "Clients";
    Layout = "_Layout";
}

<h2>Clients</h2>
<a asp-action="Create">Add New Client</a>
<table class="table table-striped">
    <thead>
        <tr><th>Name</th><th>Region</th><th>Contact</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.Region</td>
                <td>@client.ContactDetails</td>
                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@client.ClientId">Details</a>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@client.ClientId">Edit</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@client.ClientId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
