@model GLMS_Core_Prototype.Models.Contract
@{
    ViewData["Title"] = "Edit Contract";
    Layout = "_Layout";
}

<h2>Edit Contract</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ContractId" />
    <div asp-validation-summary="All"></div>
    <label>Client</label>
    <select asp-for="ClientId" asp-items="@(ViewData["Clients"] as SelectList)"></select>
    <span asp-validation-for="ClientId"></span>
    <label>Start Date</label><input asp-for="StartDate" type="date" />
    <span asp-validation-for="StartDate"></span>
    <label>End Date</label><input asp-for="EndDate" type="date" />
    <span asp-validation-for="EndDate"></span>
    <label>Region</label><input asp-for="Region" />
    <span asp-validation-for="Region"></span>
    <label>Service Level</label><input asp-for="ServiceLevel" />
    <span asp-validation-for="ServiceLevel"></span>
    <label>Status</label>
    <select asp-for="Status" asp-items="Html.GetEnumSelectList<GLMS_Core_Prototype.Models.ContractStatus>()"></select>
    <span asp-validation-for="Status"></span>
    <button type="submit">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
