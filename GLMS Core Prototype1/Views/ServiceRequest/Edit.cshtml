@model GLMS_Core_Prototype.Models.ServiceRequest
@{
    ViewData["Title"] = "Edit Service Request";
    Layout = "_Layout";
}

<h2>Edit Service Request</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ServiceRequestId" />
    <input type="hidden" asp-for="ContractId" />
    <div asp-validation-summary="All"></div>
    <label>Description</label><input asp-for="Description" />
    <span asp-validation-for="Description"></span>
    <label>Cost (USD)</label><input asp-for="CostUSD" />
    <span asp-validation-for="CostUSD"></span>
    <select asp-for="Status" asp-items="Html.GetEnumSelectList<GLMS_Core_Prototype.Models.RequestStatus>()"></select>
    <span asp-validation-for="Status"></span>
    <button type="submit">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
