@model GLMS_Core_Prototype.Models.ServiceRequest
@{
    ViewData["Title"] = "Delete Service Request";
    Layout = "_Layout";
}

<h2>Delete Service Request</h2>
<p>Are you sure you want to delete this service request?</p>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ServiceRequestId" />
    <button type="submit">Delete</button>
    <a asp-action="Details" asp-route-id="@Model.ServiceRequestId">Cancel</a>
</form>
